# Copy to .env and adjust as needed. The Go services read these from the
# environment (config via env vars only -- see CLAUDE.md). The defaults below
# match docker-compose.yml.

# --- Postgres ---
# docker-compose maps the container's 5432 to host port 5433 to avoid clashing
# with any Postgres already running on the host's default 5432.
DATABASE_URL=postgres://dispatch:dispatch@localhost:5433/dispatch?sslmode=disable

# --- Redis ---
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# --- API ---
API_PORT=8080

# --- Worker ---
# Comma-separated list of queues this worker consumes from.
QUEUES=default
