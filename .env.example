# Copy to .env and adjust as needed. The Go services read these from the
# environment (config via env vars only -- see CLAUDE.md). The defaults below
# match docker-compose.yml.

# --- Postgres ---
# docker-compose maps the container's 5432 to host port 5433 to avoid clashing
# with any Postgres already running on the host's default 5432.
DATABASE_URL=postgres://dispatch:dispatch@localhost:5433/dispatch?sslmode=disable

# --- Redis ---
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# --- API ---
API_PORT=8080

# --- Worker ---
# Comma-separated list of queues this worker consumes from.
QUEUES=default

# Address the worker serves its Prometheus /metrics on (job_latency_seconds,
# jobs_processed_total). Each worker process needs its own port; if you run more
# than one worker on the same host, override this per process.
WORKER_METRICS_ADDR=:9091

# --- API / CORS ---
# Browser origin allowed to call the API from JavaScript (the Next.js dashboard).
# Point this at your deployed dashboard origin in production.
CORS_ALLOWED_ORIGIN=http://localhost:3000

# --- Auth / sessions ---
# Server-side pepper for hashing session tokens (HMAC-SHA256). It is NOT used for
# API keys (those are long-lived and hashed with plain SHA-256). MUST be set to a
# long, random value in production: a public/default pepper weakens session
# security, and rotating it invalidates all active sessions (forces re-login).
SESSION_SECRET=dev-insecure-change-me

# Set true when the API is served over HTTPS so the session cookie carries the
# Secure flag (only sent over TLS). Keep false for the local http demo, or the
# browser won't send the cookie back over plain http.
SESSION_COOKIE_SECURE=false
